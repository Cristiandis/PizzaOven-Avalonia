<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="PizzaOven.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
        <avalonia:MaterialIconStyles />
        <StyleInclude Source="avares://PizzaOven/Controls/Button.axaml" />
        <StyleInclude Source="avares://PizzaOven/Controls/ComboBox.axaml" />
        <StyleInclude Source="avares://PizzaOven/Controls/ScrollViewer.axaml" />
    </Application.Styles>

</Application>
