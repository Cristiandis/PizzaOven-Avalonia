<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="PizzaOven.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml" />
        <avalonia:MaterialIconStyles />
        <StyleInclude Source="avares://PizzaOven/Controls/Button.axaml" />
        <StyleInclude Source="avares://PizzaOven/Controls/ComboBox.axaml" />
        <StyleInclude Source="avares://PizzaOven/Controls/ScrollViewer.axaml" />
    </Application.Styles>
    
    <Application.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#202020"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#303030"/>
        <SolidColorBrush x:Key="InnerBrush" Color="#000000"/>
        <SolidColorBrush x:Key="LoadingBrush" Color="#ffee5f"/>
        <SolidColorBrush x:Key="TextBrush" Color="#f2f2f2"/>
    </Application.Resources>

</Application>
